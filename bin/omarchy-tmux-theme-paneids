#!/bin/bash
# Variant of omarchy-tmux-theme that shows pane IDs (%N) in status bar and borders.
# Usage: run this instead of omarchy-tmux-theme when you need pane IDs visible.
#   ~/dotfiles/bin/omarchy-tmux-theme-paneids
# To revert: re-run ~/dotfiles/bin/omarchy-tmux-theme

COLOR=$(python3 -c "import json,socket,os; f=os.path.expanduser('~/dotfiles/private/tmux/colors.json'); print(json.load(open(f)).get(socket.gethostname(), 'blue') if os.path.exists(f) else 'blue')")

tmux set -g status-bg default
tmux set -g status-style "bg=default,fg=default"

tmux set -g pane-active-border-style "fg=$COLOR"
tmux set -g message-style "bg=default,fg=$COLOR"
tmux set -g message-command-style "bg=default,fg=$COLOR"
tmux set -g mode-style "bg=$COLOR,fg=black"
tmux setw -g clock-mode-colour "$COLOR"

tmux set -gu status-format

# Left: session name + active pane ID
tmux set -g status-left "#[bg=black,fg=$COLOR] #S #[fg=brightblack]#{pane_id} #[bg=default,fg=$COLOR]── "
tmux set -g status-left-length 40

# Right: hostname
tmux set -g status-right "#[fg=$COLOR]── #[bg=black,fg=$COLOR] #h #[bg=default,fg=$COLOR] ──"
tmux set -g status-right-length 40

tmux set -g status-justify left

# Inactive windows: dim, with pane ID
tmux set -g window-status-format "#[fg=brightblack]#I:#{pane_id} #W "
tmux set -g window-status-separator ""

# Active window: bright blue bold, with pane ID and process suffix
tmux set -g window-status-current-format "#[fg=brightblue,bold]#I:#{pane_id} #W#[fg=brightblue]#{?#{==:#W,#{pane_current_command}},,:#[fg=brightblue]#{=10:pane_current_command}} "

# Pane borders with pane ID
if tmux show-options -g | grep -q "pane-border-status top"; then
  tmux set -g pane-border-format "#[bg=black] #{?pane_active,#[fg=$COLOR bold],#[fg=brightblack]}─ #{pane_id} #P: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}} #[bg=default,fg=default]"
fi
