#!/bin/bash
# Adjust Hyprland monitor scale (inflate/deflate system UI and font sizes)
# Usage: hypr-zoom in | out | reset
#
# Picks the nearest "clean" scale for each monitor — one that divides the
# native resolution into whole logical pixels with even dimensions.
# Recalculates monitor positions to prevent overlaps/gaps.

MONITORS_CONF="$HOME/.config/hypr/monitors.conf"
MIN=0.50
MAX=3.00

# Build a sorted list of clean scales for a given width x height.
# A scale is clean when both width/scale and height/scale are even integers.
clean_scales() {
  local w=$1 h=$2
  awk -v w="$w" -v h="$h" 'BEGIN {
    for (i = 50; i <= 300; i++) {
      # Scale must be expressible in Wayland 120ths (i.e. i % 5 == 0)
      if (i % 5 != 0) continue
      s = i / 100.0
      lw = int(w / s + 0.5)
      lh = int(h / s + 0.5)
      if (lw * s > w - 0.01 && lw * s < w + 0.01 &&
          lh * s > h - 0.01 && lh * s < h + 0.01 &&
          lw % 2 == 0 && lh % 2 == 0) {
        printf "%.2f\n", s
      }
    }
  }'
}

configured_scale() {
  local name=$1
  if [[ -f "$MONITORS_CONF" ]]; then
    grep -E "^monitor\s*=\s*$name," "$MONITORS_CONF" | head -1 | awk -F',' '{print $NF}' | tr -d ' '
  fi
}

next_clean_up() {
  local current=$1 w=$2 h=$3
  clean_scales "$w" "$h" | awk -v c="$current" '$1 > c + 0.001 { print $1; exit }'
}

next_clean_down() {
  local current=$1 w=$2 h=$3
  clean_scales "$w" "$h" | awk -v c="$current" '$1 < c - 0.001 { last=$1 } END { if (last) print last }'
}

nearest_clean() {
  local target=$1 w=$2 h=$3
  clean_scales "$w" "$h" | awk -v t="$target" '
    BEGIN { best=""; bd=999 }
    { d = ($1 - t); if (d < 0) d = -d; if (d < bd) { bd = d; best = $1 } }
    END { print (best != "" ? best : t) }
  '
}

# Read monitor data sorted by x position (left to right)
monitors_json=$(hyprctl monitors -j | jq -c 'sort_by(.x) | .[]')

# First pass: compute new scales
declare -a names widths heights refreshes scales
i=0
while read -r monitor; do
  names[$i]=$(jq -r '.name' <<< "$monitor")
  widths[$i]=$(jq -r '.width' <<< "$monitor")
  heights[$i]=$(jq -r '.height' <<< "$monitor")
  refreshes[$i]=$(jq -r '.refreshRate' <<< "$monitor")
  current=$(jq -r '.scale' <<< "$monitor")

  case "$1" in
    in)
      new=$(next_clean_up "$current" "${widths[$i]}" "${heights[$i]}")
      new=${new:-$current}
      ;;
    out)
      new=$(next_clean_down "$current" "${widths[$i]}" "${heights[$i]}")
      new=${new:-$current}
      ;;
    reset)
      cfg=$(configured_scale "${names[$i]}")
      new=$(nearest_clean "${cfg:-1.0}" "${widths[$i]}" "${heights[$i]}")
      ;;
    *)
      echo "Usage: hypr-zoom in|out|reset" >&2
      exit 1
      ;;
  esac

  # Clamp
  if (( $(echo "$new < $MIN" | bc -l) )); then new=$MIN; fi
  if (( $(echo "$new > $MAX" | bc -l) )); then new=$MAX; fi

  scales[$i]=$new
  ((i++))
done <<< "$monitors_json"

# Second pass: compute positions left-to-right (no gaps, no overlaps)
cmds=()
x=0
for ((j=0; j<i; j++)); do
  cmds+=("keyword monitor ${names[$j]},${widths[$j]}x${heights[$j]}@${refreshes[$j]},${x}x0,${scales[$j]}")
  # Advance x by logical width of this monitor
  logical_w=$(awk "BEGIN { printf \"%d\", ${widths[$j]} / ${scales[$j]} }")
  x=$((x + logical_w))
done

# Apply all monitor changes in a single batch call
if [[ ${#cmds[@]} -gt 0 ]]; then
  batch=$(printf '%s;' "${cmds[@]}")
  hyprctl --batch "$batch"
fi
