#!/bin/bash

# Usage: hfs <query> [limit]
# Example: hfs "bert" 20

QUERY="$1"
LIMIT="${2:-100}"

if [[ -z "$QUERY" ]]; then
    echo "Usage: hfs <query> [limit]"
    echo "Example: hfs llama 50"
    exit 1
fi

python3 -c "
from huggingface_hub import HfApi
import sys

api = HfApi()
query = '$QUERY'
limit = int('$LIMIT')

try:
    models = api.list_models(
        search=query,
        limit=limit,
        sort='downloads',
        direction=-1
    )
    
    print(f'{'DOWNLOADS':<12} {'LIKES':<8} {'MODEL ID'}')
    print('-' * 60)
    
    for m in models:
        downloads = str(m.downloads)
        likes = str(m.likes)
        print(f'{downloads:<12} {likes:<8} {m.id}')

except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
"
