#!/usr/bin/env python3

import sys

from markutils.checkpoints import get_state_dict, print_state_dict_shapes


def main() -> None:
    """Prints the shapes of all tensors in a safetensors file."""
    file = sys.argv[1]
    tensors = get_state_dict(file)
    print_state_dict_shapes(tensors)


if __name__ == "__main__":
    main()
