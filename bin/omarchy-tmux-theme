#!/bin/bash
COLOR=$(python3 -c "import json,socket,os; f=os.path.expanduser('~/dotfiles/private/tmux/colors.json'); print(json.load(open(f)).get(socket.gethostname(), 'blue') if os.path.exists(f) else 'blue')")

tmux set -g status-bg default
tmux set -g status-style "bg=default,fg=default"

tmux set -g pane-active-border-style "fg=$COLOR"
tmux set -g message-style "bg=default,fg=$COLOR"
tmux set -g message-command-style "bg=default,fg=$COLOR"
tmux set -g mode-style "bg=$COLOR,fg=black"
tmux setw -g clock-mode-colour "$COLOR"

# Use status-left / status-right / window-status-format (tmux 3.4 compatible)
# Unset status-format to let status-left/right take over
tmux set -gu status-format

# Left: session name + active pane ID in black bg
tmux set -g status-left "#[bg=black,fg=$COLOR] #S #[fg=brightblack]#{pane_id} #[bg=default,fg=$COLOR]‚îÄ‚îÄ "
tmux set -g status-left-length 40

# Right: fill line + hostname
# Prepend tmux-continuum's save hook so periodic saves still fire after we
# overwrite status-right (status refresh is what triggers continuum_save.sh).
CONTINUUM_HOOK=""
if [ -x "$HOME/.config/tmux/plugins/tmux-continuum/scripts/continuum_save.sh" ]; then
  CONTINUUM_HOOK="#($HOME/.config/tmux/plugins/tmux-continuum/scripts/continuum_save.sh)"
fi
tmux set -g status-right "${CONTINUUM_HOOK}#[fg=$COLOR]‚îÄ‚îÄ #[bg=black,fg=$COLOR] #h #[bg=default,fg=$COLOR] ‚îÄ‚îÄ"
tmux set -g status-right-length 40

tmux set -g status-justify left

# Inactive windows: dim
tmux set -g window-status-format "#[fg=brightblack]#I:#{pane_id} #W "
tmux set -g window-status-separator ""

# Active window: bright blue bold, with process suffix if different
tmux set -g window-status-current-format "#[fg=brightblue,bold]#I:#{pane_id} #W#[fg=brightblue]#{?#{==:#W,#{pane_current_command}},,:#[fg=brightblue]#{=10:pane_current_command}} "

# Top pane border with black background.
#
# When the pane is the talking-stick holder (its id == contents of
# /tmp/talking-stick-holder), the ENTIRE title line is rendered in yellow
# bold ‚Äî not just the üé§ STICK prefix ‚Äî so the holder is unmistakable
# even when the title text is occluded. The left/right ‚îÄ‚îÄ‚îÄ characters
# tmux draws around the title come from pane-active-border-style /
# pane-border-style (host-theme colour); tmux has no per-pane border
# style, so those stay theme-coloured by design.
#
# Refreshes every status-interval (~2s) so the bar follows on transfer.
if [ "$(tmux show-options -gwv pane-border-status 2>/dev/null)" = "top" ]; then
  # We compare numeric ids (37 vs 37), not "%37" vs "%37" ‚Äî tmux's format
  # engine re-interprets a literal `%37` as a width directive and pads
  # with spaces, so the comparison silently fails. Strip the leading `%`
  # from pane_id via #{s/^%//:pane_id} and strip `%` (and newline) from
  # the holder file output with `tr -d "%\n"`.
  tmux set -g pane-border-format "#[bg=black] #{?#{==:#{s/^%//:pane_id},#(cat /tmp/talking-stick-holder 2>/dev/null | tr -d '%\\n')},#[fg=yellow#,bold]üé§ STICK ‚îÄ #{pane_id}: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}},#{?pane_active,#[fg=$COLOR bold],#[fg=brightblack]}‚îÄ #{pane_id}: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}}} #[bg=default,fg=default]"
fi
