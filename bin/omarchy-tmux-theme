#!/bin/bash
COLOR=$(python3 -c "import json,socket; print(json.load(open('/home/me/dotfiles/private/omp/colors.json')).get(socket.gethostname(), 'blue'))")

tmux set -g status-bg default
tmux set -g status-style "bg=default,fg=default"

tmux set -g pane-active-border-style "fg=$COLOR"
tmux set -g message-style "bg=default,fg=$COLOR"
tmux set -g message-command-style "bg=default,fg=$COLOR"
tmux set -g mode-style "bg=$COLOR,fg=black"
tmux setw -g clock-mode-colour "$COLOR"

# Use status-left / status-right / window-status-format (tmux 3.4 compatible)
# Unset status-format to let status-left/right take over
tmux set -gu status-format

# Left: session name in black bg
tmux set -g status-left "#[bg=black,fg=$COLOR] #S #[bg=default,fg=$COLOR]── "
tmux set -g status-left-length 30

# Right: fill line + hostname
tmux set -g status-right "#[fg=$COLOR]── #[bg=black,fg=$COLOR] #h #[bg=default,fg=$COLOR] ──"
tmux set -g status-right-length 40

tmux set -g status-justify left

# Inactive windows: dim
tmux set -g window-status-format "#[fg=brightblack]#I:#W "
tmux set -g window-status-separator ""

# Active window: bright blue bold, with process suffix if different
tmux set -g window-status-current-format "#[fg=brightblue,bold]#I:#W#[fg=brightblue]#{?#{==:#W,#{pane_current_command}},,:#[fg=brightblue]#{=10:pane_current_command}} "

# Top pane border with black background
if tmux show-options -g | grep -q "pane-border-status top"; then
  tmux set -g pane-border-format "#[bg=black] #{?pane_active,#[fg=$COLOR bold],#[fg=brightblack]}─ #P: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}} #[bg=default,fg=default]"
fi
