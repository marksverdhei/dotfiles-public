#!/bin/bash
# Per-host tmux accent. Resolution order:
#   1. explicit host entry in ~/dotfiles/private/tmux/colors.json (curated)
#   2. HaiOS fleet accent, ~/.config/hai-os/accent.env — gems and the kata
#      dev VMs (pilgrim, …) seed this from the hai-os accent map at start;
#      it's the only source on public-only-dotfiles boxes
#   3. plain blue
COLOR=$(python3 -c "import json,socket,os; f=os.path.expanduser('~/dotfiles/private/tmux/colors.json'); print(json.load(open(f)).get(socket.gethostname(), '') if os.path.exists(f) else '')" 2>/dev/null)
if [ -z "$COLOR" ] && [ -f "$HOME/.config/hai-os/accent.env" ]; then
  # shellcheck disable=SC1091
  . "$HOME/.config/hai-os/accent.env" 2>/dev/null
  case "${HAI_OS_ACCENT:-}" in
    \#[0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F])
      COLOR="$HAI_OS_ACCENT" ;;
  esac
fi
COLOR=${COLOR:-blue}
# Bright variant for the active-window title: named colours have a bright*
# counterpart; hex accents don't, so the hex doubles as its own bright.
case "$COLOR" in
  \#*) BRIGHT="$COLOR" ;;
  *)   BRIGHT="bright$COLOR" ;;
esac

tmux set -g status-bg default
tmux set -g status-style "bg=default,fg=default"

tmux set -g pane-active-border-style "fg=$COLOR"
tmux set -g message-style "bg=default,fg=$COLOR"
tmux set -g message-command-style "bg=default,fg=$COLOR"
tmux set -g mode-style "bg=$COLOR,fg=black"
tmux setw -g clock-mode-colour "$COLOR"

# Use status-left / status-right / window-status-format (tmux 3.4 compatible)
# Unset status-format to let status-left/right take over
tmux set -gu status-format

# Left: session name + active pane ID in black bg
tmux set -g status-left "#[bg=black,fg=$COLOR] #S #[fg=brightblack]#{pane_id} #[bg=default,fg=$COLOR]── "
tmux set -g status-left-length 40

# Right: fill line + hostname
# Prepend tmux-continuum's save hook so periodic saves still fire after we
# overwrite status-right (status refresh is what triggers continuum_save.sh).
CONTINUUM_HOOK=""
if [ -x "$HOME/.config/tmux/plugins/tmux-continuum/scripts/continuum_save.sh" ]; then
  CONTINUUM_HOOK="#($HOME/.config/tmux/plugins/tmux-continuum/scripts/continuum_save.sh)"
fi
tmux set -g status-right "${CONTINUUM_HOOK}#[fg=$COLOR]── #[bg=black,fg=$COLOR] #h #[bg=default,fg=$COLOR] ──"
tmux set -g status-right-length 40

tmux set -g status-justify left

# Inactive windows: dim
tmux set -g window-status-format "#[fg=brightblack]#I:#{pane_id} #W "
tmux set -g window-status-separator ""

# Active window: bright accent bold, with process suffix if different
tmux set -g window-status-current-format "#[fg=$BRIGHT,bold]#I:#{pane_id} #W#[fg=$BRIGHT]#{?#{==:#W,#{pane_current_command}},,:#[fg=$BRIGHT]#{=10:pane_current_command}} "

# Top pane border with black background.
#
# When the pane is the talking-stick holder (its id == contents of
# /tmp/talking-stick-holder), the ENTIRE title line is rendered in yellow
# bold — not just the 🎤 STICK prefix — so the holder is unmistakable
# even when the title text is occluded. The left/right ─── characters
# tmux draws around the title come from pane-active-border-style /
# pane-border-style (host-theme colour); tmux has no per-pane border
# style, so those stay theme-coloured by design.
#
# A ❤ prefix is added when the pane has a live heartbeat. The match
# uses tmux's `#{m:pattern,string}` against ` %5 %7 …`-style output
# from `heartbeat tmux-active-panes`; the surrounding spaces guarantee
# word-boundary matches so `%5` doesn't bleed into `%50`.
#
# Refreshes every status-interval (~2s) so the bar follows on transfer.
if [ "$(tmux show-options -gwv pane-border-status 2>/dev/null)" = "top" ]; then
  # We compare numeric ids (37 vs 37), not "%37" vs "%37" — tmux's format
  # engine re-interprets a literal `%37` as a width directive and pads
  # with spaces, so the comparison silently fails. Strip the leading `%`
  # from pane_id via #{s/^%//:pane_id} and strip `%` (and newline) from
  # the holder file output with `tr -d "%\n"`.
  tmux set -g pane-border-format "#[bg=black] #{?#{m:* #{pane_id} *,#(cat /tmp/heartbeat-active-panes 2>/dev/null)},#[fg=red#,bold]❤ #[bg=black],}#{?#{==:#{s/^%//:pane_id},#(cat /tmp/talking-stick-holder 2>/dev/null | tr -d '%\\n')},#[fg=yellow#,bold]🎤 STICK ─ #{pane_id}: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}},#{?pane_active,#[fg=$COLOR bold],#[fg=brightblack]}─ #{pane_id}: #{?#{!=:#{pane_title},#{host}},#{pane_title},#{pane_current_command}}} #[bg=default,fg=default]"
fi
