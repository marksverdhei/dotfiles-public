#!/bin/bash

# Source the necessary functions
source "$HOME/.bashrc.d/00-pre.sh"
source "$HOME/.bashrc.d/vars/theme.sh"
source "$HOME/.bashrc.d/functions/theme.sh"

# Extract background color from a Ghostty theme file
get_theme_background() {
  local theme_file="$1"
  awk -F'=' '
    BEGIN{IGNORECASE=1}
    /^[[:space:]]*background[[:space:]]*=/ {
      gsub(/[[:space:]]/, "", $2); print $2; exit
    }' "$theme_file"
}

# Calculate luminance using Rec. 709 formula
# Returns luminance value scaled by 10000 (0 = black, ~2,550,000 = white)
calculate_luminance() {
  local hex="$1"
  local r g b
  r=$((16#${hex:0:2}))
  g=$((16#${hex:2:2}))
  b=$((16#${hex:4:2}))
  # Rec. 709 luminance: L = 0.2126*R + 0.7152*G + 0.0722*B
  # Scaled by 10000 to avoid floating point: (2126*R + 7152*G + 722*B)
  echo $(( 2126*r + 7152*g + 722*b ))
}

# Check if a theme matches the current system appearance (light/dark)
theme_matches_system() {
  local luminance="$1"
  local threshold=1280000  # Mid-gray (#808080)

  if [[ "${SYS_THEME:-dark}" == "dark" ]]; then
    # Dark mode: only include themes with luminance < threshold
    [[ $luminance -lt $threshold ]]
  else
    # Light mode: only include themes with luminance >= threshold
    [[ $luminance -ge $threshold ]]
  fi
}

# Get a random theme that matches the system appearance
get_random_matching_theme() {
  while IFS= read -r -d '' theme_file; do
    local bg name hex lum

    bg=$(get_theme_background "$theme_file")
    [[ $bg =~ ^#[0-9A-Fa-f]{6}$ ]] || continue

    name=$(basename -- "$theme_file")
    hex=${bg#\#}
    lum=$(calculate_luminance "$hex")

    if theme_matches_system "$lum"; then
      printf '%s\n' "$name"
    fi
  done < <(find "$GHOSTTY_THEME_DIR" -maxdepth 1 -type f -print0) | shuf -n 1
}

# Main: Randomize theme if enabled
if [ "$GHOSTTY_RANDOM_THEME" = "true" ] && [ -d "$GHOSTTY_THEME_DIR" ]; then
  random_theme=$(get_random_matching_theme)
  if [ -n "$random_theme" ]; then
    ghostty_set_current_theme "$random_theme"
  fi
fi

# Launch ghostty
exec ghostty "$@"
