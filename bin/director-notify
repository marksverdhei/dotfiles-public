#!/bin/bash
# director-notify — watch director's inter-agent send log and fire a branded
# desktop notification for every agent-to-agent message. Pairs with notify-agent
# (sender's avatar = icon, "from → to" = title, message = body).
#
#   director-notify            # foreground; tails the send log (Ctrl-C to stop)
#   director-notify --once     # process one synthetic test line and exit (self-test)
#   director-notify --status   # is a watcher already running?
#
# Autostarted from ~/.config/hypr/autostart.conf so the whole fleet's comms
# surface as toasts on this desktop. Single watcher per box covers all agents.
set -uo pipefail

# Self-contained PATH: autostart launchers (uwsm/systemd) may not inherit the
# login shell's PATH, but we hard-depend on notify-agent (dotfiles/bin) and the
# director/jq tooling, so guarantee they resolve.
export PATH="$HOME/dotfiles/bin:$HOME/.local/bin:$PATH"

LOG="${AGENT_EVENTS_LOG:-$HOME/.local/share/agent-tools/events.jsonl}"
TTL="${DIRECTOR_NOTIFY_TTL:-8000}"

die() { echo "director-notify: $*" >&2; exit 1; }
command -v jq          >/dev/null || die "missing jq"
command -v notify-agent >/dev/null || die "missing notify-agent (dotfiles/bin)"

# Strip the <message ...>BODY</message> envelope down to BODY; collapse newlines.
strip_envelope() {
  printf '%s' "$1" \
    | sed -E 's#^[[:space:]]*<message[^>]*>##; s#</message>[[:space:]]*$##' \
    | tr '\n' ' '
}

# Fire one notification from a single JSONL line. Returns 0 if it was a send.
emit() {
  local line="$1" kind from to msg body
  kind=$(printf '%s' "$line" | jq -r '.kind // empty' 2>/dev/null) || return 1
  [[ $kind == send ]] || return 1
  from=$(printf '%s' "$line" | jq -r '.from // "agent"' 2>/dev/null)
  to=$(printf '%s'   "$line" | jq -r '.to   // "?"'     2>/dev/null)
  msg=$(printf '%s'  "$line" | jq -r '.msg  // ""'      2>/dev/null)
  body=$(strip_envelope "$msg")
  [[ -z ${body// } ]] && body="(no message body)"
  notify-agent --as "$from" "$from → $to" "$body" -t "$TTL" 2>/dev/null || true
  return 0
}

case "${1:-}" in
  --status)
    pids=$(pgrep -f 'director-notify$|director-notify ' | grep -v "^$$\$" || true)
    if [[ -n $pids ]]; then echo "running (pid: $(echo "$pids" | tr '\n' ' '))"; exit 0
    else echo "not running"; exit 1; fi ;;
  --once)
    emit '{"kind":"send","from":"crystal-mom","to":"centurion","msg":"<message from=\"agent:crystal-mom\" to=\"agent:centurion\">self-test: director-notify is live.</message>"}' \
      && echo "fired test notification" || die "self-test failed"
    exit 0 ;;
  -h|--help) sed -n '2,12p' "$0"; exit 0 ;;
  "") : ;;
  *) die "unknown arg $1" ;;
esac

[[ -r $LOG ]] || die "no events log at $LOG"

# Follow only NEW lines (start at end). -F survives rotation/truncation.
tail -n0 -F "$LOG" 2>/dev/null | while IFS= read -r line; do
  emit "$line" || true
done
